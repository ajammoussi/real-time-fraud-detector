# ── SeaweedFS / S3 ──────────────────────────────────────────────
SEAWEED_ACCESS_KEY=minioadmin
SEAWEED_SECRET_KEY=minioadmin
SEAWEED_ENDPOINT=http://seaweedfs-s3:8333
DATALAKE_BUCKET=datalake

# ── AWS credentials for MLflow S3 artifact download ──────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ── MLflow ──────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow-server:5000
MLFLOW_S3_ENDPOINT_URL=http://seaweedfs-s3:8333
MLFLOW_EXPERIMENT_NAME=fraud_detection

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mlops
POSTGRES_USER=mlops
POSTGRES_PASSWORD=mlops_secret

# ── Kafka ───────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_TRANSACTIONS_RAW=transactions_raw
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_PREDICTIONS=predictions
KAFKA_CONSUMER_GROUP=prediction-workers
KAFKA_CONSUMER_GROUP_LAKE=lake-writers

# ── Binance WebSocket (public feed, no auth required) ────────────
# Docs: https://developers.binance.com/docs/binance-spot-api-docs/web-socket-streams
BINANCE_WS_BASE=wss://stream.binance.com:9443/stream
BINANCE_SYMBOLS=btcusdt,ethusdt,bnbusdt,solusdt,xrpusdt

# ── Streaming-to-lake batch settings ────────────────────────────
LAKE_BATCH_SIZE=1000
LAKE_BATCH_TIMEOUT_SECS=300

# ── Redis ───────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── Feast ───────────────────────────────────────────────────────
FEAST_REPO_PATH=./feast

# ── API ─────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=change_me_in_prod
SHADOW_TRAFFIC_FRACTION=1.0
MODEL_NAME=fraud_detector
MODEL_STAGE=Production

# ── GitHub Actions ──────────────────────────────────────────────
GITHUB_TOKEN=replace_with_github_token
GITHUB_OWNER=your-org
GITHUB_REPO=real-time-fraud-detector
