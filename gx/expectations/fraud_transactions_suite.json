{
  "expectation_suite_name": "fraud_transactions_suite",
  "expectations": [
    {"expectation_type": "expect_column_values_to_not_be_null",
     "kwargs": {"column": "transaction_id"}},
    {"expectation_type": "expect_column_values_to_not_be_null",
     "kwargs": {"column": "amount_usd"}},
    {"expectation_type": "expect_column_values_to_not_be_null",
     "kwargs": {"column": "label"}},
    {"expectation_type": "expect_column_values_to_be_between",
     "kwargs": {"column": "amount_usd", "min_value": 0.01, "max_value": 50000}},
    {"expectation_type": "expect_column_values_to_be_in_set",
     "kwargs": {"column": "device_type",
                "value_set": [
                  "mobile","desktop","tablet","pos_terminal",
                  "exchange_maker","exchange_taker"
                ]}},
    {"expectation_type": "expect_column_values_to_be_in_set",
     "kwargs": {"column": "label", "value_set": [0, 1]}},
    {"expectation_type": "expect_table_row_count_to_be_between",
     "kwargs": {"min_value": 100, "max_value": 10000000}},
    {"expectation_type": "expect_column_proportion_of_unique_values_to_be_between",
     "kwargs": {"column": "transaction_id", "min_value": 0.99, "max_value": 1.0}}
  ]
}
